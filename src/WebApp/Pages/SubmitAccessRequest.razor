@page "/en/submit-access-request"
@page "/fr/soumettre-une-demande"

<h1>@Localizer["Submit Access Request"]</h1>

@if (SurveyCompleted)
{
    <Loading />
}

<Survey Id="surveyElementSubmitAccessRequest"
