@page "/health-and-safety-measures"
@page "/mesures-de-sante-et-de-securite-relatives"

@inject IStringLocalizer<App> Localizer

<h1>@Localizer["Health & Safety Measures"]</h1>

@if (SurveyData is null || TermsAndConditionsState.Value.IsLoading)
{
    <Loading />
}
else
{
    <Survey Id="surveyElementPrivacyAct"
            SurveyUrl="sample-data/healthSafetyMeasuresSurvey.json"
            OnSurveyCompleted="@OnSurveyCompleted"
            Data="@SurveyData" />
}

@if (SurveyCompleted)
{
    <Loading />
}