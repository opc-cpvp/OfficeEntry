@inherits Fluxor.Blazor.Web.Components.FluxorComponent

@page "/privacy-act-statement"
@page "/protection-des-renseignements-personnels"

@inject IStringLocalizer<App> Localizer

<h1>@Localizer["Privacy Act Statement"]</h1>

@if (SurveyData is null || TermsAndConditionsState.Value.IsLoading)
{
    <Loading />
}
else
{
    <Survey Id="surveyElementPrivacyAct"
            SurveyUrl="sample-data/privacyActStatementSurvey.json"
            OnSurveyCompleted="@OnSurveyCompleted"
            Data="@SurveyData" />
}

@if (SurveyCompleted)
{
    <Loading />
}